# Repository root — copy to `.env` and fill in values.
# Loaded by some Spring Boot apps via spring.config.import (e.g. backend/events, backend/ticketing, backend/user_and_organizations).

# --- OIDC / JWT (asymmetric RS*/ES* via JWKS) ---
# Ticketing, events, user & organizations services: discovery document supplies issuer + jwks_uri; JWT header `kid` selects the public key.
SUPABASE_OIDC_DISCOVERY_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/openid-configuration

# --- Service host ports (local / Docker Compose published ports) ---
# Gateway is the single entry point on 8080. Other apps use distinct host ports when run directly or via Compose.
GATEWAY_PORT=8080
AUTH_API_PORT=8085
USER_SERVICE_PORT=8081
EVENT_SERVICE_PORT=8082
ADMIN_SERVICE_PORT=8083
TICKETING_SERVICE_PORT=8084

# --- Gateway: downstream URIs when running gateway locally (`./gradlew bootRun`) ---
# Defaults in application.yml are http://localhost:<port> matching the ports above.
# Uncomment to override, e.g. point at Docker service names only works from another container on sharks-infra.
# GATEWAY_SERVICE_AUTH_URI=http://localhost:8085
# GATEWAY_SERVICE_USER_URI=http://localhost:8081
# GATEWAY_SERVICE_EVENT_URI=http://localhost:8082
# GATEWAY_SERVICE_TICKETING_URI=http://localhost:8084
# GATEWAY_SERVICE_ADMIN_URI=http://localhost:8083

# --- Supabase Storage (events service — JPEG uploads via S3-compatible API) ---
# S3 endpoint: found in Supabase dashboard → Storage → S3 Connection
SUPABASE_STORAGE_URL=https://<project-ref>.storage.supabase.co/storage/v1/s3
# Bucket name (must exist in Supabase; public-read policy is applied automatically on startup)
SUPABASE_STORAGE_BUCKET=event-images
# S3 access key / secret key (Supabase dashboard → Storage → S3 Connection → Access keys)
SUPABASE_STORAGE_ACCESS_KEY=
SUPABASE_STORAGE_SECRET_KEY=
