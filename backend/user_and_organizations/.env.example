# User & organizations service — copy variables into the repository ROOT `.env` (recommended)
# or export them before running. Spring loads root `.env` via application.properties:
#   spring.config.import=optional:file:../../../../.env[.properties]
#
# Docker Compose can pass the same variables; see docker-compose.yml.

# Required for JWT auth: OpenID Connect discovery URL (asymmetric JWTs only: RS256, ES256, etc.).
# Fetches issuer + jwks_uri; access tokens must be signed with a key published at jwks_uri (header kid matches a JWK).
SUPABASE_OIDC_DISCOVERY_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/openid-configuration

# Typical local run (optional overrides)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/sharks
# USER_SERVICE_PORT=8081
