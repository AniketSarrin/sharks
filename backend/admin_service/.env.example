# OIDC discovery: issuer + JWKS for JWT verification (Supabase Auth).
# Copy to repo-root `.env`, this folder's `.env`, or export before `docker compose up`.
SUPABASE_OIDC_DISCOVERY_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/openid-configuration

# Optional local defaults (override in `.env`)
# SERVER_PORT=8083
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/sharks
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=postgres
